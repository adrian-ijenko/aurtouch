  },
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/adrian-ijenko/AirTouch-Homebridge.git"
  },
  "bugs": {
    "url": "https://github.com/adrian-ijenko/AirTouch-Homebridge/issues"
  },
  "homepage": "https://github.com/adrian-ijenko/AirTouch-Homebridge#readme",
  "homebridge": {
    "pluginAlias": "AirTouchHomebridge",
    "pluginType": "platform"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "homebridge": "^1.8.5",
    "typescript": "^5.4.5"
  }
}
