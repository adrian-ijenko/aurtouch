{
  "name": "homebridge-airtouch",
  "version": "2.0.0",
  "description": "AirTouch Homebridge — HomeKit for Polyaire AirTouch 2+ wall panels (TCP)",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "prepublishOnly": "npm run build",
    "probe": "node scripts/probe-panel.cjs"
